<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Actor / Producer OS</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box}
  :root{
    --ink:#1a1a1a; --ink-soft:#3f4550;
    --steel:#2e5f8a; --steel-dark:#234b6e; --steel-light:#e8f0f7;
    --paper:#f4f2ee; --panel:#ffffff; --panel-alt:#f7f6f3;
    --line:#dcdad4; --line-soft:#e8e6e0;
    --muted:#6b7280; --muted2:#565c66;
    --amber:#b8791f; --amber-bg:#fbf3e2;
    --good:#2f7d51; --good-bg:#eaf5ee; --good-line:#bfe0cd;
    --warn:#b23b3b; --warn-bg:#fbecec;
    --gold:#c9a94e;
  }
  html{-webkit-text-size-adjust:100%}
  body{
    font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
    -webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;
    background:var(--paper);color:var(--ink);line-height:1.45;
  }
  .mono{font-family:'SF Mono',ui-monospace,Menlo,Consolas,monospace}

  /* ---------- header ---------- */
  .top{background:var(--steel-dark);color:#fff;border-bottom:3px solid var(--gold)}
  .top-inner{max-width:1120px;margin:0 auto;padding:22px 20px 20px;display:flex;justify-content:space-between;align-items:flex-end;gap:16px;flex-wrap:wrap}
  .brand h1{font-size:23px;font-weight:800;letter-spacing:2px;text-transform:uppercase}
  .brand .tag{font-size:11px;color:#a9c4dc;letter-spacing:1.5px;text-transform:uppercase;margin-top:3px}
  .stagepill{text-align:right}
  .stagepill .lab{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:#9db9d2}
  .stagepill .val{font-size:15px;font-weight:800;color:#fff;margin-top:2px}
  .stagepill .role{font-size:11px;color:#c6d8e8}

  /* ---------- nav ---------- */
  nav{background:var(--panel);border-bottom:1px solid var(--line);position:sticky;top:0;z-index:20;overflow-x:auto;-webkit-overflow-scrolling:touch}
  .nav-inner{max-width:1120px;margin:0 auto;display:flex;padding:0 10px}
  nav button{background:none;border:none;cursor:pointer;font-family:inherit;white-space:nowrap;
    padding:13px 15px;font-size:11px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;
    color:var(--muted);border-bottom:2px solid transparent}
  nav button:hover{color:var(--ink)}
  nav button.on{color:var(--steel);border-bottom-color:var(--steel)}
  nav button:focus-visible{outline:2px solid var(--steel);outline-offset:-2px}

  /* ---------- layout ---------- */
  .wrap{max-width:1120px;margin:0 auto;padding:22px 20px 60px}
  .grid{display:grid;gap:16px}
  .g2{grid-template-columns:1fr 1fr}
  .g3{grid-template-columns:repeat(3,1fr)}
  @media(max-width:820px){.g2,.g3{grid-template-columns:1fr}}

  .panel{background:var(--panel);border:1px solid var(--line);border-radius:3px}
  .panel-h{display:flex;justify-content:space-between;align-items:center;gap:10px;
    padding:13px 16px;border-bottom:1px solid var(--line-soft)}
  .panel-h h2{font-size:12px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--ink)}
  .panel-h .sub{font-size:11px;color:var(--muted)}
  .panel-b{padding:16px}
  .panel-b.tight{padding:12px}

  .eyebrow{font-size:10px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;color:var(--steel);margin-bottom:8px}
  .lead{font-size:13px;color:var(--muted2)}

  /* generic bits */
  .row{display:flex;justify-content:space-between;align-items:flex-start;gap:12px}
  .row.mid{align-items:center}
  .col{display:flex;flex-direction:column}
  .wrap-gap>*+*{margin-top:14px}
  .gap8>*+*{margin-top:8px}
  .gap12>*+*{margin-top:12px}
  .flex{display:flex} .aic{align-items:center} .jcsb{justify-content:space-between}
  .gap6{gap:6px}.gap10{gap:10px} .wraprow{flex-wrap:wrap}
  .grow{flex:1}
  .r{text-align:right}
  .t10{font-size:10px}.t11{font-size:11px}.t12{font-size:12px}.t13{font-size:13px}.t15{font-size:15px}.t18{font-size:18px}.t22{font-size:22px}
  .b7{font-weight:700}.b8{font-weight:800}
  .mut{color:var(--muted)}.mut2{color:var(--muted2)}.ital{font-style:italic}
  .mt4{margin-top:4px}.mt6{margin-top:6px}.mt8{margin-top:8px}.mt10{margin-top:10px}.mt14{margin-top:14px}
  .mb4{margin-bottom:4px}.mb6{margin-bottom:6px}.mb8{margin-bottom:8px}.mb10{margin-bottom:10px}.mb14{margin-bottom:14px}

  .cell{border:1px solid var(--line);border-radius:3px;padding:12px;background:var(--panel-alt)}
  .cell.plain{background:var(--panel)}

  .stat .n{font-size:22px;font-weight:800;letter-spacing:-.5px}
  .stat .l{font-size:10px;letter-spacing:.8px;text-transform:uppercase;color:var(--muted);margin-top:2px}
  .stat .d{font-size:11px;color:var(--muted2);margin-top:3px}

  .bar{height:7px;background:var(--line);border-radius:99px;overflow:hidden}
  .bar>span{display:block;height:100%;background:var(--steel);border-radius:99px;transition:width .35s}
  .bar.gold>span{background:var(--gold)}
  .bar.good>span{background:var(--good)}

  .tag-el{display:inline-block;font-size:10px;font-weight:800;letter-spacing:.5px;text-transform:uppercase;padding:3px 8px;border-radius:3px}
  .t-steel{background:var(--steel);color:#fff}
  .t-steel-soft{background:var(--steel-light);color:var(--steel-dark)}
  .t-good{background:var(--good-bg);color:var(--good);border:1px solid var(--good-line)}
  .t-amber{background:var(--amber-bg);color:var(--amber)}
  .t-gray{background:#eceae5;color:var(--muted2)}
  .t-gold{background:#f6efd8;color:#8a6d1f}

  .callout{border:1px solid var(--line);border-left:3px solid var(--steel);border-radius:3px;padding:12px 14px;background:var(--panel-alt)}
  .callout.amber{border-left-color:var(--amber);background:var(--amber-bg)}
  .callout.good{border-left-color:var(--good);background:var(--good-bg)}

  /* buttons */
  .btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;cursor:pointer;border:none;font-family:inherit;
    padding:8px 13px;font-size:11px;font-weight:800;letter-spacing:.6px;text-transform:uppercase;border-radius:3px;color:#fff;background:var(--steel)}
  .btn:hover{background:var(--steel-dark)}
  .btn.sm{padding:6px 10px;font-size:10px}
  .btn.ghost{background:transparent;color:var(--steel);border:1px solid var(--steel)}
  .btn.ghost:hover{background:var(--steel-light)}
  .btn.gray{background:#8b9099}.btn.gray:hover{background:#6f747d}
  .btn.good{background:var(--good)}.btn.good:hover{background:#256540}
  .btn.warn{background:transparent;color:var(--warn);border:1px solid #e6b9b9}
  .btn.warn:hover{background:var(--warn-bg)}
  .btn:focus-visible{outline:2px solid var(--gold);outline-offset:2px}
  .btn:disabled{opacity:.45;cursor:not-allowed}
  .iconbtn{background:none;border:none;cursor:pointer;color:var(--muted);font-size:12px;padding:4px 6px;border-radius:3px;font-family:inherit}
  .iconbtn:hover{background:var(--line-soft);color:var(--ink)}

  /* forms */
  label.fl{display:block;font-size:10px;font-weight:800;letter-spacing:.6px;text-transform:uppercase;color:var(--muted2);margin-bottom:4px}
  input,textarea,select{width:100%;font-family:inherit;font-size:14px;color:var(--ink);background:#fff;
    border:1px solid var(--line);border-radius:3px;padding:8px 10px}
  input:focus,textarea:focus,select:focus{outline:2px solid var(--steel);outline-offset:1px;border-color:var(--steel)}
  textarea{resize:vertical;min-height:52px}
  .field+.field{margin-top:10px}
  .f2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  @media(max-width:560px){.f2{grid-template-columns:1fr}}
  input[type=range]{padding:0;height:20px;accent-color:var(--steel)}
  input[type=checkbox]{width:auto;accent-color:var(--steel);width:16px;height:16px}

  /* modal */
  .scrim{position:fixed;inset:0;background:rgba(26,26,26,.5);display:flex;align-items:flex-start;justify-content:center;
    padding:32px 16px;z-index:100;overflow-y:auto}
  .modal{background:#fff;border-radius:4px;width:100%;max-width:520px;border:1px solid var(--line);box-shadow:0 20px 50px rgba(0,0,0,.25)}
  .modal-h{padding:14px 16px;border-bottom:1px solid var(--line-soft);display:flex;justify-content:space-between;align-items:center}
  .modal-h h3{font-size:13px;font-weight:800;letter-spacing:.8px;text-transform:uppercase}
  .modal-b{padding:16px}
  .modal-f{padding:12px 16px;border-top:1px solid var(--line-soft);display:flex;justify-content:flex-end;gap:8px}

  /* list item card */
  .item{border:1px solid var(--line);border-radius:3px;padding:13px;background:var(--panel-alt)}
  .item+.item{margin-top:10px}
  .item.hl{border-left:3px solid var(--steel)}
  .item.done{border-left:3px solid var(--good);background:var(--good-bg)}
  .item.lock{opacity:.72}

  /* matrix table */
  .mtx{width:100%;border-collapse:collapse;font-size:12px}
  .mtx th,.mtx td{border-bottom:1px solid var(--line-soft);padding:9px 8px;text-align:left;vertical-align:top}
  .mtx th{font-size:10px;letter-spacing:.6px;text-transform:uppercase;color:var(--muted);font-weight:800}
  .mtx td.num{text-align:right;font-variant-numeric:tabular-nums;white-space:nowrap}
  .mtx tr.win td{background:var(--good-bg)}
  .scorechip{display:inline-block;min-width:34px;text-align:center;font-weight:800;padding:2px 6px;border-radius:3px;background:var(--steel-light);color:var(--steel-dark);font-variant-numeric:tabular-nums}
  .scorechip.top{background:var(--good);color:#fff}

  /* gate row */
  .gate{display:flex;gap:10px;align-items:flex-start;padding:9px 0;border-bottom:1px solid var(--line-soft)}
  .gate:last-child{border-bottom:none}
  .gate .gi{font-size:11px;font-weight:800;color:var(--muted);width:20px;flex:none;text-align:right;padding-top:1px}
  .gate label{flex:1;display:flex;gap:9px;align-items:flex-start;cursor:pointer}
  .gate .gt{font-size:12px;color:var(--ink-soft)}
  .gate.ok .gt{color:var(--good);font-weight:600}

  /* stepper */
  .steps{display:flex;gap:6px;flex-wrap:wrap}
  .step{flex:1;min-width:130px;border:1px solid var(--line);border-radius:3px;padding:10px;background:var(--panel-alt)}
  .step.cur{border-color:var(--steel);border-width:2px;background:var(--steel-light)}
  .step.past{background:var(--good-bg);border-color:var(--good-line)}
  .step .sn{font-size:10px;font-weight:800;letter-spacing:.5px;color:var(--muted)}
  .step.cur .sn{color:var(--steel)}
  .step .st{font-size:12px;font-weight:800;margin-top:2px}
  .step .sr{font-size:10px;color:var(--muted);margin-top:2px}

  /* playbook rung */
  .rung{display:flex;gap:12px;padding:12px 0;border-bottom:1px solid var(--line-soft)}
  .rung:last-child{border-bottom:none}
  .rung .rnum{flex:none;width:26px;height:26px;border-radius:50%;background:var(--steel);color:#fff;font-size:12px;font-weight:800;display:flex;align-items:center;justify-content:center}
  .rung .rbody{flex:1}
  .rung .rt{font-size:13px;font-weight:800}
  .rung .rmeta{font-size:11px;color:var(--steel);font-weight:700;margin-top:1px}
  .rung .rd{font-size:12px;color:var(--muted2);margin-top:4px}
  .rung .rlesson{font-size:11px;color:var(--ink-soft);margin-top:5px;padding:6px 9px;background:var(--steel-light);border-radius:3px}

  .foot{border-top:1px solid var(--line);background:var(--panel);padding:18px;margin-top:8px}
  .foot p{max-width:1120px;margin:0 auto;font-size:11px;color:var(--muted);text-align:center}

  .empty{text-align:center;padding:22px;color:var(--muted);font-size:12px}
  .divider{height:1px;background:var(--line-soft);margin:14px 0}
  a.lk{color:var(--steel);text-decoration:none;font-weight:700}
  a.lk:hover{text-decoration:underline}
  ::-webkit-scrollbar{width:9px;height:9px}
  ::-webkit-scrollbar-thumb{background:#cfccc4;border-radius:5px}
  @media(prefers-reduced-motion:reduce){*{transition:none!important}}
</style>
</head>
<body>
<div id="app"></div>
<div id="modal-root"></div>

<script>
"use strict";

/* =====================================================================
   ACTOR / PRODUCER OS  —  v3
   Dependency-free. Plain JS + inline CSS. localStorage persistence.
   Rebuilt with: full CRUD, weighted decision matrix, Curry Barker
   playbook, distribution paths, crowdfunding tracker.
   ===================================================================== */

var STORE_KEY = 'actor-producer-os-v3';
var uid = function(){ return Date.now().toString(36) + Math.random().toString(36).slice(2,6); };
var todayISO = function(){ return new Date().toISOString().slice(0,10); };

/* ---------------- Stage model ---------------- */
var STAGES = {
  s0:{name:'Create the Proof', role:'Actor-Creator',
      bottom:'Not enough finished public work to create leverage.',
      grad:'Finish a starter body of work and release proof publicly.'},
  s1:{name:'Build the Signal', role:'Audience Builder',
      bottom:'Work exists, but attention and output are not yet repeatable.',
      grad:'Prove a specific kind of work repeatedly earns audience response.'},
  s2:{name:'Earn the Credit', role:'Actor-Producer',
      bottom:'Proof exists but is not yet a financeable package or industry credit.',
      grad:'Turn proof into a strong package with external credibility.'},
  s3:{name:'Package & Finance', role:'Lead Producer',
      bottom:'The project is promising but not yet ready to greenlight.',
      grad:'Make one feature fully financeable and production-ready.'},
  s4:{name:'Deliver & Leverage', role:'Working Actor-Producer',
      bottom:'The win is a one-off unless it makes the next project better.',
      grad:'Deliver, capture the leverage, package the next projects fast.'},
  s5:{name:'Build the Slate', role:'Creator-Producer / Studio Builder',
      bottom:'The career still depends on one project at a time.',
      grad:'Run a repeatable slate with dependable money and distribution.'}
};
var SKEYS = ['s0','s1','s2','s3','s4','s5'];

var DEFAULT_GATES = {
  s0:['Write 5 sketch scripts','Produce and publish at least 3 of them',
      "Complete Feature 1's first draft",'Log 4+ acting class or practice sessions',
      'Finish one project from footage ingest to final export','Lock in 3+ recurring collaborators'],
  s1:['Publish 10+ total pieces','Identify the strongest repeatable format from real data',
      'Finish one polished short or proof-of-concept',"Complete Feature 2's first draft",
      'Capture an owned-audience channel and hit a starter threshold','Earn a first creative-revenue milestone'],
  s2:["Complete Feature 3's first draft",'Earn one credible external signal (festival, press, credit, rep)',
      'Pick one feature as the lead project','Build the full package (deck, look book, budget, schedule, wish list)',
      'Grow 5+ warm stage-relevant relationships','Hold 3+ serious package / finance / distribution talks'],
  s3:['Lock script and chain of title','Build line-item budget, schedule, finance plan, recoupment model',
      'Set cast, director, department-head, and location strategy','Choose a distribution path and deliverables plan',
      'Get fundraising materials reviewed by qualified counsel','Secure the financing or an approved budget',
      'Set a real production start date'],
  s4:['Complete and deliver the film','Execute the distribution or self-release plan',
      'Record audience, press, revenue, and festival outcomes','Convert collaborators and financiers into durable relationships',
      'Package 2+ follow-up projects',"Improve the next project's terms using proven leverage"],
  s5:['Maintain a prioritized 3-project slate','Establish repeat financing and distribution paths',
      'Build a reliable core production team','Keep direct access to the audience',
      'Track project profitability, rights, and recoupment','Reduce dependence on any single buyer or financier']
};

/* ---------------- Curry Barker playbook (researched) ---------------- */
var PLAYBOOK = [
  {n:1,t:'Build the training ground',meta:'2017–2023 · ~$0',
   d:'Met Cooper Tomlinson at film school, started "that\u2019s a bad idea" within days, dropped out after a year to post consistently. Hundreds of sketches across YouTube and TikTok grew the channel past 1M subscribers.',
   lesson:'Volume is the film school. Every sketch was reps in writing, directing, editing, acting. Audience was the byproduct.',
   maps:'s0'},
  {n:2,t:'Release a proof-of-concept short',meta:'2023 · "The Chair"',
   d:'An award-winning horror short, now 5.5M+ views. This is the one that made industry people (producer James Harris) reach out.',
   lesson:'A short opens the door. Know which asset does which job.',
   maps:'s1'},
  {n:3,t:'Ship a calling-card feature, cheap',meta:'2024 · "Milk & Serial" · $800',
   d:'62-min found-footage feature, shot weekends over 4 months with friends. Most of the $800 paid one actor and a camcorder, which they resold for $100 profit. Self-released free on YouTube after a year of failed distribution talks. Hit 2M+ views and landed UTA representation.',
   lesson:'Try the traditional path, but do not be its hostage. Reach and proof beat a small licensing check.',
   maps:'s1'},
  {n:4,t:'Convert proof into a financed feature',meta:'2025 · "Obsession" · $750K financed',
   d:'Capstone Studios fully financed it after the founder read the script. Shot in ~20\u201326 days. Premiered at TIFF Midnight Madness; Focus Features bought it for ~$15M in a bidding war. Blumhouse\u2019s Jason Blum joined as EP.',
   lesson:'Proof compresses the timeline. Once the ratio is proven, the money finds you.',
   maps:'s3'},
  {n:5,t:'Deliver, over-perform, cash the leverage',meta:'2026 · $400M+ worldwide',
   d:'Obsession grew 30% in its second weekend and crossed $400M on a sub-$1M budget. Before it even finished its run, Focus pre-bought his next feature "Anything But Ghosts" and A24 hired him to direct a "Texas Chain Saw Massacre" reimagining.',
   lesson:'One delivered, over-performing feature becomes a multi-studio slate. That is graduation.',
   maps:'s4'}
];

/* ---------------- Distribution paths ---------------- */
var DIST_PATHS = [
  {name:'Self-release (free / ad-supported)', example:'Milk & Serial on YouTube',
   money:1, reach:4, control:5, speed:5,
   note:'Trade a licensing fee for maximum reach, audience ownership, and proof. Zero gatekeepers.'},
  {name:'Festival \u2192 acquisition', example:'Obsession \u2192 Focus for ~$15M',
   money:5, reach:5, control:2, speed:1,
   note:'Premiere at a top festival to manufacture a bidding war, then sell rights to a studio with real muscle.'},
  {name:'Streaming license', example:'Shudder / Netflix / Hulu',
   money:4, reach:4, control:2, speed:2,
   note:'A flat or MG license to a platform. Good money and reach, less upside and control.'},
  {name:'Theatrical four-wall (self)', example:'Rent screens directly',
   money:2, reach:2, control:4, speed:2,
   note:'You keep control and the theatrical credit, but you carry the P&A risk yourself.'},
  {name:'PVOD / TVOD direct', example:'Sell/rent direct to viewers',
   money:3, reach:3, control:4, speed:4,
   note:'Direct transactional sales to your own audience. Fast, controllable, moderate ceiling.'},
  {name:'Hybrid windowing', example:'Festival + limited theatrical + PVOD',
   money:4, reach:4, control:3, speed:2,
   note:'Sequence the windows to stack proof, press, and revenue. More work to orchestrate.'}
];

/* ---------------- Seed data ---------------- */
function seed(){
  return {
    v:'3.0', updated:new Date().toISOString(),
    stageOverride:null,
    gates: JSON.parse(JSON.stringify(DEFAULT_GATES)),
    gateDone:{},
    // matrix weights (0-5) + option scores editable
    matrix:{
      criteria:[
        {id:'c1',name:'Builds finished, owned asset',weight:5},
        {id:'c2',name:'Grows owned audience',weight:4},
        {id:'c3',name:'Earns industry proof / credit',weight:4},
        {id:'c4',name:'Low cost / cash-safe',weight:3},
        {id:'c5',name:'Uses a warm collaborator I already have',weight:3},
        {id:'c6',name:'Moves the current binding constraint',weight:5}
      ],
      options:[
        {id:'o1',name:'Finish Feature 1 draft',scores:{c1:5,c2:1,c3:3,c4:5,c5:2,c6:5}},
        {id:'o2',name:'Shoot + publish next sketch',scores:{c1:4,c2:5,c3:2,c4:4,c5:5,c6:3}},
        {id:'o3',name:'Cut a proof-of-concept short',scores:{c1:5,c2:4,c3:5,c4:2,c5:4,c6:4}},
        {id:'o4',name:'Chase a festival submission',scores:{c1:1,c2:2,c3:5,c4:3,c5:1,c6:2}}
      ]
    },
    features:[
      {id:uid(),title:'The Long Game',genre:'Drama',target:120,pages:45,status:'Drafting',
       logline:'A former athlete finds a second act coaching kids in a struggling neighborhood.',
       sessions:[
        {id:uid(),date:'2024-06-15',pages:8,notes:'Opening sequence, tone'},
        {id:uid(),date:'2024-06-17',pages:10,notes:'Meet the kids'},
        {id:uid(),date:'2024-06-20',pages:12,notes:'Conflict with admin'},
        {id:uid(),date:'2024-06-25',pages:15,notes:'Mid-point turn'}
       ]},
      {id:uid(),title:'Common Ground',genre:'Comedy-Drama',target:110,pages:0,status:'Not Started',
       logline:'Two estranged siblings inherit a community garden and must save it together.',sessions:[]},
      {id:uid(),title:'Untitled Project 3',genre:'TBD',target:120,pages:0,status:'Not Started',
       logline:'TBD',sessions:[]}
    ],
    sketches:[
      {id:uid(),title:'Morning Ritual',genre:'Comedy',status:'Published',views:'',logline:'A guy realizes his morning routine is performative for his cat.'},
      {id:uid(),title:'Cold Call',genre:'Drama',status:'Published',views:'',logline:'A recruiter dials a wrong number and opens up to a stranger.'},
      {id:uid(),title:'Parallel Lives',genre:'Drama',status:'Produced',views:'',logline:'Two versions of one person at different turning points, one scene.'},
      {id:uid(),title:'The Callback',genre:'Comedy',status:'Written',views:'',logline:"An actor preps for an audition he's done 100 times."},
      {id:uid(),title:'Last Shift',genre:'Drama',status:'Idea',views:'',logline:'A manager trains his replacement on his last day.'}
    ],
    acting:{title:'Advanced Scene Study',instructor:'Michael Chen',
      focus:['Character Development','Subtext','Emotional Authenticity'],
      sessions:[
        {id:uid(),date:'2024-04-01',type:'Scene Study Class',focus:'Character Development',notes:'Stanislavski method for character history.',adj:'Write detailed character bios before scene work.'},
        {id:uid(),date:'2024-04-08',type:'Scene Study Class',focus:'Subtext',notes:'What lives underneath the dialogue.',adj:'Mark subtext on every script page.'},
        {id:uid(),date:'2024-04-15',type:'Solo Practice',focus:'Emotional Authenticity',notes:'Reaching real emotion without forcing.',adj:'Ten-minute emotional recall daily.'},
        {id:uid(),date:'2024-04-22',type:'Scene Study Class',focus:'Character Development',notes:'Monologue work, voice and physicality.',adj:'Record monologues weekly, review patterns.'}
