/* ---------------- State ---------------- */
var S=null, tab='dash', modal=null;

function load(){
  try{ var r=localStorage.getItem(STORE_KEY); if(r){ var d=JSON.parse(r); return migrate(d); } }catch(e){}
  return seed();
}
function migrate(d){
  // ensure new fields exist so older saves don't break
  var base=seed();
  for(var k in base){ if(!(k in d)) d[k]=base[k]; }
  if(!d.gates) d.gates=JSON.parse(JSON.stringify(DEFAULT_GATES));
  if(!d.gateDone) d.gateDone={};
  if(!d.matrix) d.matrix=base.matrix;
  if(!d.funding) d.funding=[];
  if(!d.crowdfund) d.crowdfund=base.crowdfund;
  if(!d.project) d.project=base.project;
  return d;
}
function persist(){ try{ S.updated=new Date().toISOString(); localStorage.setItem(STORE_KEY,JSON.stringify(S)); }catch(e){} }
function commit(){ persist(); render(); }

/* ---------------- Computations ---------------- */
function computedStage(){
  for(var i=0;i<SKEYS.length;i++){
    var k=SKEYS[i], gs=S.gates[k]||[], done=0;
    for(var g=0;g<gs.length;g++){ if(S.gateDone[k+'-'+g]) done++; }
    if(done<gs.length) return k;
  }
  return 's5';
}
function curStage(){ return S.stageOverride||computedStage(); }
function stagePct(k){
  var gs=S.gates[k]||[]; if(!gs.length) return {done:0,total:0,pct:0};
  var done=0; for(var g=0;g<gs.length;g++){ if(S.gateDone[k+'-'+g]) done++; }
  return {done:done,total:gs.length,pct:Math.round(done/gs.length*100)};
}
function binding(k){
  var gs=S.gates[k]||[];
  for(var g=0;g<gs.length;g++){ if(!S.gateDone[k+'-'+g]) return {text:gs[g],rule:g+1,idx:g}; }
  return null;
}
function activeFeature(){ for(var i=0;i<S.features.length;i++){ if(S.features[i].status==='Drafting') return S.features[i]; } return null; }
function anyDrafting(){ return !!activeFeature(); }
function avgPages(f){ if(!f.sessions.length) return null; var t=0; f.sessions.forEach(function(s){t+=(+s.pages||0);}); return t/f.sessions.length; }
function warmStageRel(k){ return S.relationships.filter(function(r){ return (r.warmth==='Warm'||r.warmth==='Active Collaborator') && r.stages.indexOf(k)>-1; }).length; }
function fundingTotals(){
  var committed=0,received=0; S.funding.forEach(function(f){committed+=(+f.committed||0);received+=(+f.received||0);});
  var gap=Math.max(0,(+S.project.budget||0)-committed);
  return {committed:committed,received:received,gap:gap};
}
function matrixResults(){
  var m=S.matrix, out=[];
  var wsum=0; m.criteria.forEach(function(c){ wsum+=(+c.weight||0); });
  m.options.forEach(function(o){
    var raw=0; m.criteria.forEach(function(c){ raw+=(+c.weight||0)*(+((o.scores||{})[c.id])||0); });
    var maxRaw=wsum*5;
    out.push({id:o.id,name:o.name,raw:raw,pct: maxRaw? Math.round(raw/maxRaw*100):0});
  });
  out.sort(function(a,b){return b.raw-a.raw;});
  return out;
}
function money(n){ n=+n||0; return '$'+n.toLocaleString(); }

/* auto-sync feature completion into gates */
function syncGates(){
  if(S.features[0]) S.gateDone['s0-2']=S.features[0].pages>=S.features[0].target;
  if(S.features[1]) S.gateDone['s1-3']=S.features[1].pages>=S.features[1].target;
  if(S.features[2]) S.gateDone['s2-0']=S.features[2].pages>=S.features[2].target;
}
function nextFeatureUnlocked(){
  // Feature n draftable only if Feature n-1 first draft complete
  var out=[];
  for(var i=0;i<S.features.length;i++){
    if(i===0) out.push(true);
    else out.push(S.features[i-1].pages>=S.features[i-1].target);
  }
  return out;
}

/* ---------------- DOM helper ---------------- */
function el(tag,attrs,kids){
  var e=document.createElement(tag);
  if(attrs) for(var k in attrs){
    var v=attrs[k];
    if(v==null||v===false) continue;
    if(k==='class') e.className=v;
    else if(k==='html') e.innerHTML=v;
    else if(k[0]==='o'&&k[1]==='n'&&typeof v==='function') e.addEventListener(k.slice(2).toLowerCase(),v);
    else if(k==='style') e.setAttribute('style',v);
    else if(k==='value') e.value=v;
    else if(k==='checked'){ if(v) e.checked=true; }
    else e.setAttribute(k,v);
  }
  if(kids!=null){ if(!Array.isArray(kids)) kids=[kids];
    kids.forEach(function(c){ if(c==null||c===false) return;
      if(typeof c==='string'||typeof c==='number') e.appendChild(document.createTextNode(''+c));
      else e.appendChild(c); }); }
  return e;
}
