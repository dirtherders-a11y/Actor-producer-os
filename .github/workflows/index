  ]);

  // distribution comparison
  var distPanel=el('div',{class:'panel'},[
    el('div',{class:'panel-h'},[el('h2',null,'Distribution paths'),el('span',{class:'sub'},'Money · Reach · Control · Speed (0\u20135)')]),
    el('div',{class:'panel-b gap12'}, DIST_PATHS.map(function(d){
      var chosen=d.name===S.project.chosenDist;
      var meter=function(lab,val){ return el('div',{class:'flex aic gap8'},[el('span',{class:'t10 mut',style:'width:56px'},lab),el('div',{class:'grow'},bar(val*20)),el('span',{class:'t10 mut',style:'width:14px'},val)]); };
      return el('div',{class:'item '+(chosen?'hl':'')},[
        el('div',{class:'flex jcsb aic wraprow gap6 mb6'},[
          el('div',null,[el('div',{class:'t13 b8'},d.name),el('div',{class:'t11 mut'},'e.g. '+d.example)]),
          chosen? el('span',{class:'tag-el t-steel'},'Chosen') : el('button',{class:'btn ghost sm',onClick:function(){ S.project.chosenDist=d.name; commit(); }},'Choose')
        ]),
        el('div',{class:'t12 mut2 mb8'},d.note),
        el('div',{class:'gap6'},[meter('Money',d.money),meter('Reach',d.reach),meter('Control',d.control),meter('Speed',d.speed)])
      ]);
    }))
  ]);

  // crowdfunding
  var cf=S.crowdfund;
  var cfPct=cf.goal? Math.round(cf.raised/cf.goal*100):0;
  var cfPanel=el('div',{class:'panel'},[
    el('div',{class:'panel-h'},[el('h2',null,'Crowdfunding'),el('button',{class:'btn ghost sm',onClick:cfModal},'Edit campaign')]),
    el('div',{class:'panel-b'}, cf.platform? el('div',null,[
      el('div',{class:'flex jcsb aic wraprow gap8 mb8'},[
        el('div',{class:'flex gap6 aic'},[el('span',{class:'tag-el t-steel'},cf.platform), cf.live? el('span',{class:'tag-el t-good'},'Live'):el('span',{class:'tag-el t-gray'},'Draft')]),
        cf.deadline? el('span',{class:'t11 mut'},'Deadline '+cf.deadline):null
      ]),
      el('div',{class:'flex jcsb aic t12 mb4'},[el('span',{class:'b7'},money(cf.raised)+' raised'),el('span',{class:'mut'},'of '+money(cf.goal)+' · '+cfPct+'%')]),
      bar(cfPct, cfPct>=100?'good':'gold'),
      el('div',{class:'t11 mut mt8'},cf.backers+' backers · Your owned audience ('+(S.owned.email+S.owned.sms)+') is the engine that makes this work.')
    ]) : el('div',{class:'empty'},'No campaign yet. Crowdfunding turns your owned audience into the financier. Set one up when you have a project to fund.'))
  ]);

  // top summary
  var summary=el('div',{class:'panel'},[
    el('div',{class:'panel-h'},[el('h2',null,'Lead project'),el('button',{class:'btn ghost sm',onClick:projModal},'Edit')]),
    el('div',{class:'panel-b'},[
      el('div',{class:'grid g3'},[
        stat(S.project.budget?money(S.project.budget):'Not set','Budget'),
        stat(money(ft.committed),'Committed', ft.received?money(ft.received)+' received':null),
        stat(S.project.budget?money(ft.gap):'Not measured','Funding gap','max(0, budget \u2212 committed)')
      ]),
      el('div',{class:'callout mt14'},[el('span',{class:'t11 b8',style:'color:var(--steel)'},'Discipline. '),el('span',{class:'t12 mut2'},'Follower growth and a verbal "interested" are not committed financing. Only money marked Committed or Received counts toward the gap.')])
    ])
  ]);

  return el('div',{class:'wrap-gap'},[summary, el('div',{class:'grid g2'},[fundPanel,cfPanel]), distPanel]);
}

