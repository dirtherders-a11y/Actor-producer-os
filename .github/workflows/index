/* ---------- DECISIONS LOG ---------- */
function viewDecisions(){
  var decModal=function(existing){
    var r={};
    openModal(existing?'Edit decision':'Log decision', function(b){
      b.appendChild(el('div',{class:'field'},[el('label',{class:'fl'},'Decision'), inp(r,'decision',{value:existing?existing.decision:''})]));
      b.appendChild(el('div',{class:'field mt10'},[el('label',{class:'fl'},'Evidence that forced it'), txt(r,'evidence',{value:existing?existing.evidence:''})]));
      b.appendChild(el('div',{class:'f2 mt10'},[
        el('div',null,[el('label',{class:'fl'},'Date'), inp(r,'date',{type:'date',value:existing?existing.date:todayISO()})]),
        el('div',null,[el('label',{class:'fl'},'Status'), sel(r,'status',['Active','Reversed','Superseded','Parked'], existing?existing.status:'Active')])
      ]));
    }, function(){
      var d=r.decision.value.trim(); if(!d){ r.decision.focus(); return false; }
      var obj={decision:d,evidence:r.evidence.value.trim(),date:r.date.value,status:r.status.value};
      if(existing){ Object.assign(existing,obj); } else { obj.id=uid(); S.decisions.unshift(obj); }
      persist(); render();
    }, existing?'Save':'Log');
  };
  return el('div',{class:'panel'},[
    el('div',{class:'panel-h'},[el('h2',null,'Decision Log'),el('button',{class:'btn sm',onClick:function(){decModal(null);}},'+ Decision')]),
    el('div',{class:'panel-b gap12'}, S.decisions.length? S.decisions.map(function(d){
      var stTag=d.status==='Active'?'t-good':d.status==='Parked'?'t-amber':'t-gray';
      return el('div',{class:'item'},[
        el('div',{class:'flex jcsb aic wraprow gap6 mb6'},[
          el('div',{class:'t13 b8'},d.decision),
          el('div',{class:'flex gap6 aic'},[el('span',{class:'tag-el '+stTag},d.status),
            el('button',{class:'iconbtn',onClick:function(){decModal(d);}},'\u270e'),
            el('button',{class:'iconbtn',onClick:function(){ S.decisions=S.decisions.filter(function(x){return x!==d;}); commit(); }},'\u2715')
          ])
        ]),
        d.evidence? el('div',{class:'t12 mut2'},[el('b',null,'Because. '),d.evidence]):null,
        el('div',{class:'t11 mut mt4'},d.date)
      ]);
    }) : el('div',{class:'empty'},'No decisions logged.'))
  ]);
}

/* ---------- SETTINGS ---------- */
function viewSettings(){
  var k=curStage();
  var stageBtns=el('div',{class:'gap8'}, SKEYS.map(function(sk){
    var on=S.stageOverride===sk;
    return el('button',{class:'btn '+(on?'':'ghost')+' sm',style:'width:100%;justify-content:flex-start',
      onClick:function(){ S.stageOverride = on?null:sk; commit(); }},
      'Stage '+sk.slice(1)+' · '+STAGES[sk].name+(on?'  · OVERRIDE':''));
  }));

  var exportBtn=el('button',{class:'btn',style:'width:100%',onClick:function(){
    var blob=new Blob([JSON.stringify(S,null,2)],{type:'application/json'});
    var url=URL.createObjectURL(blob);
    var a=el('a',{href:url,download:'actor-producer-os-'+todayISO()+'.json'});
    document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
  }},'Export backup (JSON)');
  var importBtn=el('button',{class:'btn good',style:'width:100%',onClick:function(){
    var i=el('input',{type:'file',accept:'.json'});
    i.addEventListener('change',function(e){ var file=e.target.files[0]; if(!file) return;
      var rd=new FileReader(); rd.onload=function(ev){
        try{ var obj=JSON.parse(ev.target.result); if(obj&&obj.features){ S=migrate(obj); persist(); render(); alert('Backup restored.'); } else alert('Invalid file: missing expected fields.'); }
        catch(err){ alert('Invalid JSON file.'); } };
      rd.readAsText(file); });
    i.click();
  }},'Restore from backup');
  var resetBtn=el('button',{class:'btn warn',style:'width:100%',onClick:function(){
    openModal('Reset everything',function(b){ b.appendChild(el('p',{class:'t13 mut2'},'This wipes your data and reloads the starting example. Export a backup first if you want to keep anything.')); },
    function(){ S=seed(); persist(); render(); },'Reset');
  }},'Reset to example data');

  var owned={};
  var ownedModal=function(){
    var r={};
    openModal('Owned audience & revenue', function(b){
      b.appendChild(el('div',{class:'f2'},[
        el('div',null,[el('label',{class:'fl'},'Email subscribers'), inp(r,'email',{type:'number',value:S.owned.email})]),
        el('div',null,[el('label',{class:'fl'},'SMS subscribers'), inp(r,'sms',{type:'number',value:S.owned.sms})])
      ]));
      b.appendChild(el('div',{class:'field mt10'},[el('label',{class:'fl'},'Creative revenue to date'), inp(r,'rev',{type:'number',value:S.revenue})]));
      b.appendChild(el('p',{class:'t11 mut2 mt8'},'Published count is computed from your sketch statuses automatically.')); 
    }, function(){
      S.owned.email=+r.email.value||0; S.owned.sms=+r.sms.value||0; S.revenue=+r.rev.value||0; persist(); render();
    });
  };

  return el('div',{class:'grid g2'},[
    el('div',{class:'panel'},[
      el('div',{class:'panel-h'},[el('h2',null,'Stage override')]),
      el('div',{class:'panel-b'},[
        el('p',{class:'t12 mut2 mb10'},'Stage is auto-computed from your gates. Override only to preview another stage. The computed stage keeps showing when no override is set. Current computed: Stage '+computedStage().slice(1)+'.'),
        stageBtns
      ])
    ]),
    el('div',{class:'wrap-gap'},[
      el('div',{class:'panel'},[
        el('div',{class:'panel-h'},[el('h2',null,'Owned audience & revenue'),el('button',{class:'btn ghost sm',onClick:ownedModal},'Edit')]),
        el('div',{class:'panel-b'},[
          el('div',{class:'grid g3'},[
            stat(S.owned.email,'Email'),
            stat(S.owned.sms,'SMS'),
            stat(S.revenue?money(S.revenue):'Not measured','Revenue')
          ])
        ])
      ]),
      el('div',{class:'panel'},[
        el('div',{class:'panel-h'},[el('h2',null,'Backup & restore')]),
        el('div',{class:'panel-b gap8'},[
          el('p',{class:'t12 mut2'},'Data lives in this browser only. Export regularly and keep the file somewhere safe.'),
          exportBtn, importBtn, el('div',{class:'divider'}), resetBtn,
          el('div',{class:'t11 mut mt8'},'Schema v'+S.v+' · saved '+new Date(S.updated).toLocaleString())
        ])
      ])
    ])
  ]);
}

/* =====================================================================
   SHELL
   ===================================================================== */
var TABS=[
  {id:'dash',label:'Dashboard',view:viewDash},
  {id:'matrix',label:'Decision Matrix',view:viewMatrix},
  {id:'writing',label:'Writing',view:viewWriting},
  {id:'acting',label:'Acting',view:viewActing},
  {id:'rel',label:'Relationships',view:viewRel},
  {id:'stage',label:'Stage Progress',view:viewStage},
  {id:'money',label:'Financing & Distribution',view:viewMoney},
  {id:'play',label:'Barker Playbook',view:viewPlay},
  {id:'decisions',label:'Decisions',view:viewDecisions},
  {id:'settings',label:'Settings',view:viewSettings}
];

function render(){
  syncGates();
  var k=curStage(), st=STAGES[k];
  var root=document.getElementById('app'); root.innerHTML='';

  var top=el('div',{class:'top'}, el('div',{class:'top-inner'},[
    el('div',{class:'brand'},[el('h1',null,'Actor / Producer OS'),el('div',{class:'tag'},'Grassroots career operating system')]),
    el('div',{class:'stagepill'},[
      el('div',{class:'lab'},'Current stage'),
      el('div',{class:'val'},'S'+k.slice(1)+' · '+st.name),
      el('div',{class:'role'},st.role)
    ])
  ]));

  var navInner=el('div',{class:'nav-inner'});
  TABS.forEach(function(t){ navInner.appendChild(el('button',{class:tab===t.id?'on':'',onClick:function(){tab=t.id;render();window.scrollTo(0,0);}},t.label)); });
  var nav=el('nav',null,navInner);

  var cur=TABS.filter(function(t){return t.id===tab;})[0]||TABS[0];
  var body=el('div',{class:'wrap'}, cur.view());

  var foot=el('div',{class:'foot'}, el('p',null,'Data persists locally in this browser. Back it up in Settings. Not legal or financial advice; get qualified counsel before any fundraising or deal.'));

  root.appendChild(top); root.appendChild(nav); root.appendChild(body); root.appendChild(foot);
}

/* ---------------- boot ---------------- */
try{
  S=load(); render();
}catch(err){
  document.getElementById('app').innerHTML=
    '<div style="padding:26px;font-family:sans-serif;max-width:560px;margin:0 auto">'+
    '<h2 style="margin-bottom:8px;color:#234b6e">Could not load the app</h2>'+
    '<p style="color:#565c66;font-size:14px">'+(err&&err.message?err.message:'Unknown error')+'</p>'+
    '<button onclick="localStorage.removeItem(\''+STORE_KEY+'\');location.reload()" '+
    'style="margin-top:14px;padding:9px 15px;background:#2e5f8a;color:#fff;border:none;border-radius:3px;font-weight:800;cursor:pointer">Reset & reload</button></div>';
}
</script>
