        el('div',{class:'grid g2'},[
          el('div',{class:'cell'},[el('div',{class:'eyebrow'},'The training ground'),el('div',{class:'t12 mut2'},'Hundreds of sketches across YouTube (1.1M) and TikTok (1.4M). Every upload was reps in writing, directing, editing, acting.')]),
          el('div',{class:'cell'},[el('div',{class:'eyebrow'},'The door-opener'),el('div',{class:'t12 mut2'},'"The Chair" short, 5.5M+ views. A short film, not a feature, is what made producers reach out.')]),
          el('div',{class:'cell'},[el('div',{class:'eyebrow'},'The calling card'),el('div',{class:'t12 mut2'},'"Milk & Serial," $800, shot weekends over 4 months. Sold the camera for $100 profit. Free on YouTube \u2192 UTA rep.')]),
          el('div',{class:'cell'},[el('div',{class:'eyebrow'},'The cash-out'),el('div',{class:'t12 mut2'},'"Obsession" financed by one financier who read the script, sold at TIFF for ~$15M, then a two-studio slate before it finished its run.')])
