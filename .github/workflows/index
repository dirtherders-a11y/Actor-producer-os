/* ---------- DECISION MATRIX ---------- */
function viewMatrix(){
  var m=S.matrix, res=matrixResults();
  var topId=res[0]?res[0].id:null;

  var critModal=function(existing){
    var r={};
    openModal(existing?'Edit criterion':'Add criterion', function(b){
      b.appendChild(el('div',{class:'field'},[el('label',{class:'fl'},'Criterion'), inp(r,'name',{value:existing?existing.name:''})]));
      b.appendChild(el('div',{class:'field mt10'},[el('label',{class:'fl'},'Weight (0\u20135)'), inp(r,'weight',{type:'number',min:'0',max:'5',value:existing?existing.weight:3})]));
    }, function(){
      var name=r.name.value.trim(); if(!name){ r.name.focus(); return false; }
      var w=Math.max(0,Math.min(5,+r.weight.value||0));
      if(existing){ existing.name=name; existing.weight=w; }
      else{ var id='c'+uid(); m.criteria.push({id:id,name:name,weight:w}); m.options.forEach(function(o){ o.scores[id]=3; }); }
      persist(); render();
    }, existing?'Save':'Add');
  };
  var optModal=function(existing){
    var r={};
    openModal(existing?'Edit option':'Add option', function(b){
      b.appendChild(el('div',{class:'field'},[el('label',{class:'fl'},'Option / move'), inp(r,'name',{value:existing?existing.name:''})]));
      if(!existing) b.appendChild(el('p',{class:'t11 mut2 mt8'},'Scores start at 3 for each criterion. Tune them in the table.'));
    }, function(){
      var name=r.name.value.trim(); if(!name){ r.name.focus(); return false; }
      if(existing){ existing.name=name; }
      else{ var scores={}; m.criteria.forEach(function(c){ scores[c.id]=3; }); m.options.push({id:'o'+uid(),name:name,scores:scores}); }
      persist(); render();
    }, existing?'Save':'Add');
  };

  // build editable matrix table
  var thead=el('tr',null,[el('th',null,'Move \u2193  /  Criterion \u2192')].concat(
    m.criteria.map(function(c){
      return el('th',null,[
        el('div',{class:'flex jcsb aic gap6'},[
          el('span',null,c.name),
          el('span',{class:'flex gap6'},[
            el('button',{class:'iconbtn',title:'Edit',onClick:function(){critModal(c);}},'\u270e'),
            el('button',{class:'iconbtn',title:'Remove',onClick:function(){ m.criteria=m.criteria.filter(function(x){return x!==c;}); m.options.forEach(function(o){delete o.scores[c.id];}); commit(); }},'\u2715')
          ])
        ]),
        el('div',{class:'t10 mut',style:'font-weight:600;text-transform:none;letter-spacing:0'},'weight '+c.weight)
      ]);
    })
  ).concat([el('th',{class:'r'},'Score')]));

  var rows=m.options.map(function(o){
    var r=res.filter(function(x){return x.id===o.id;})[0];
    var tds=[el('td',null,[
      el('div',{class:'flex jcsb aic gap6'},[
        el('span',{class:'b7'},o.name),
        el('span',{class:'flex gap6'},[
          el('button',{class:'iconbtn',onClick:function(){optModal(o);}},'\u270e'),
          el('button',{class:'iconbtn',onClick:function(){ m.options=m.options.filter(function(x){return x!==o;}); commit(); }},'\u2715')
        ])
      ])
    ])];
    m.criteria.forEach(function(c){
      var v=(o.scores||{})[c.id]; if(v==null) v=0;
      var input=el('input',{type:'number',min:'0',max:'5',value:v,style:'width:52px;padding:4px 6px;text-align:center',
        onChange:function(e){ var nv=Math.max(0,Math.min(5,+e.target.value||0)); o.scores[c.id]=nv; e.target.value=nv; commit(); }});
      tds.push(el('td',{class:'num'},input));
    });
    tds.push(el('td',{class:'num'}, el('span',{class:'scorechip '+(o.id===topId?'top':'')}, r?r.raw:0)));
    return el('tr',{class:o.id===topId?'win':''}, tds);
  });

  var table=el('div',{style:'overflow-x:auto'}, el('table',{class:'mtx'},[el('thead',null,thead),el('tbody',null,rows)]));

  var ranking=el('div',{class:'panel'},[
    el('div',{class:'panel-h'},[el('h2',null,'Ranked outcome')]),
    el('div',{class:'panel-b gap8'}, res.map(function(r,i){
      return el('div',null,[
        el('div',{class:'flex jcsb aic t12 mb4'},[
          el('span',{class:'b7'},(i+1)+'. '+r.name),
          el('span',{class:'mut'},r.raw+' pts · '+r.pct+'%')
        ]),
        bar(r.pct, i===0?'good':'')
      ]);
    }))
  ]);

  return el('div',{class:'wrap-gap'},[
    el('div',{class:'panel'},[
      el('div',{class:'panel-h'},[el('h2',null,'Decision Matrix'),el('span',{class:'sub'},'Weighted. Score each move 0\u20135 per criterion.')]),
      el('div',{class:'panel-b'},[
        el('p',{class:'t12 mut2 mb14'},'Weight the criteria to your values, score each move, and the engine ranks them. The Barker lens is baked into the defaults: finished owned assets and audience beat vanity activity. Edit anything.'),
        table,
        el('div',{class:'flex gap8 mt14 wraprow'},[
          el('button',{class:'btn ghost sm',onClick:function(){critModal(null);}},'+ Criterion'),
          el('button',{class:'btn ghost sm',onClick:function(){optModal(null);}},'+ Move')
        ])
      ])
    ]),
    ranking
  ]);
}

