                      React.createElement(
                        'span',
                        { className: 'inline-block px-2 py-1 bg-orange-400 text-white text-xs font-bold rounded' },
                        'ACTIVE'
                      )
                  ),
                  React.createElement('div', { className: 'text-xs text-gray-600 mb-3 italic' }, `"${feature.logline}"`),
                  React.createElement(
                    'div',
                    { className: 'flex items-center gap-4' },
                    React.createElement(
                      'div',
                      { className: 'flex-1' },
                      React.createElement(
                        'div',
                        { className: 'flex justify-between mb-1' },
                        React.createElement('span', { className: 'text-xs font-semibold text-gray-700' }, 'Progress'),
                        React.createElement('span', { className: 'text-xs text-gray-600' }, `${feature.currentPages} / ${feature.targetPages} pages`)
                      ),
                      React.createElement(
                        'div',
                        { className: 'w-full bg-gray-300 rounded-full h-2' },
                        React.createElement('div', {
                          className: 'bg-orange-400 h-2 rounded-full transition-all',
                          style: { width: `${Math.min((feature.currentPages / feature.targetPages) * 100, 100)}%` },
                        })
                      )
                    ),
                    React.createElement('div', { className: 'text-xs text-gray-600' }, `${feature.writingSessions.length} sessions`)
                  )
                )
              )
            )
          ),
          // Add session
          activeFeature &&
            React.createElement(
              'div',
              { className: 'border border-gray-300 rounded p-4 bg-gray-50' },
              !showNewSession
                ? React.createElement(
                    'button',
                    {
                      onClick: () => setShowNewSession(true),
                      className: 'w-full px-3 py-2 bg-orange-400 text-white text-xs font-bold uppercase rounded hover:bg-orange-500 transition',
                    },
                    '+ Log Writing Session'
                  )
                : React.createElement(
                    'div',
                    { className: 'space-y-3' },
                    React.createElement(
                      'div',
                      null,
                      React.createElement('label', { className: 'block text-xs font-semibold text-gray-700 mb-1' }, 'Pages (minimum 3)'),
                      React.createElement('input', {
                        type: 'number',
                        min: '3',
                        value: sessionPages,
                        onChange: (e) => setSessionPages(e.target.value),
                        className: 'w-full px-2 py-1 border border-gray-300 rounded text-sm',
                      })
                    ),
                    React.createElement(
                      'div',
                      null,
                      React.createElement('label', { className: 'block text-xs font-semibold text-gray-700 mb-1' }, 'Notes (optional)'),
                      React.createElement('textarea', {
                        value: sessionNotes,
                        onChange: (e) => setSessionNotes(e.target.value),
                        className: 'w-full px-2 py-1 border border-gray-300 rounded text-sm',
                        rows: 2,
                      })
                    ),
                    React.createElement(
                      'div',
                      { className: 'flex gap-2' },
                      React.createElement(
                        'button',
                        {
                          onClick: handleAddSession,
                          className: 'flex-1 px-3 py-2 bg-green-600 text-white text-xs font-bold rounded hover:bg-green-700',
                        },
                        'Save'
                      ),
                      React.createElement(
                        'button',
                        {
                          onClick: () => setShowNewSession(false),
                          className: 'flex-1 px-3 py-2 bg-gray-400 text-white text-xs font-bold rounded hover:bg-gray-500',
                        },
                        'Cancel'
                      )
                    )
                  )
            ),
          // Sketches
          React.createElement(
            'div',
            null,
            React.createElement('h3', { className: 'text-xs font-bold uppercase tracking-wide text-gray-700 mb-3' }, 'Sketch Scripts'),
            React.createElement(
              'div',
              { className: 'space-y-2' },
              data.sketchScripts.map((sketch) =>
                React.createElement(
                  'div',
                  { key: sketch.id, className: 'border border-gray-300 rounded p-3' },
                  React.createElement(
                    'div',
                    { className: 'flex justify-between items-start mb-1' },
                    React.createElement(
                      'div',
                      null,
                      React.createElement('div', { className: 'text-sm font-semibold text-gray-900' }, sketch.title),
                      React.createElement('div', { className: 'text-xs text-gray-600' }, sketch.genre)
                    ),
                    React.createElement(
                      'span',
                      {
                        className: `text-xs px-2 py-1 rounded font-semibold ${
                          sketch.status === 'Published'
                            ? 'bg-green-100 text-green-800'
                            : sketch.status === 'Produced'
                              ? 'bg-blue-100 text-blue-800'
                              : 'bg-gray-100 text-gray-800'
                        }`,
                      },
                      sketch.status
                    )
                  ),
                  React.createElement('div', { className: 'text-xs text-gray-600 italic mb-2' }, `"${sketch.logline}"`),
                  sketch.link && React.createElement('a', { href: sketch.link, className: 'text-xs text-orange-600 hover:underline' }, 'View →')
                )
              )
            )
          )
        )
      );
    }

    function ActingModule({ data }) {
      const actingClass = data.actingClass;

      return React.createElement(
        'div',
        { className: 'bg-white rounded border border-gray-200 p-6' },
        React.createElement('h2', { className: 'text-xs font-bold uppercase tracking-wide text-gray-900 mb-4 pb-3 border-b border-gray-200' }, 'Acting'),
        actingClass
          ? React.createElement(
              'div',
              { className: 'space-y-4' },
              React.createElement(
                'div',
                { className: 'border border-gray-300 rounded p-4 bg-gray-50' },
                React.createElement('div', { className: 'text-sm font-bold text-gray-900 mb-1' }, actingClass.title),
                React.createElement('div', { className: 'text-xs text-gray-600 mb-3' }, `Instructor: ${actingClass.instructor}`),
                React.createElement(
                  'div',
                  { className: 'flex flex-wrap gap-2 mb-3' },
                  actingClass.focusAreas.map((area) =>
                    React.createElement('span', { key: area, className: 'text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded' }, area)
                  )
                ),
                React.createElement('div', { className: 'text-xs text-gray-700' }, React.createElement('strong', null, 'Sessions: '), `${actingClass.sessions.length} logged`)
              ),
              React.createElement(
                'div',
                null,
                React.createElement('h3', { className: 'text-xs font-bold uppercase tracking-wide text-gray-700 mb-2' }, 'Session History'),
                React.createElement(
                  'div',
                  { className: 'space-y-2' },
                  actingClass.sessions.map((session) =>
                    React.createElement(
                      'div',
                      { key: session.id, className: 'border border-gray-200 rounded p-3' },
                      React.createElement(
                        'div',
                        { className: 'flex justify-between items-start mb-2' },
                        React.createElement('div', { className: 'text-xs font-semibold text-gray-900' }, session.classOrPractice),
                        React.createElement('div', { className: 'text-xs text-gray-600' }, session.date)
                      ),
                      React.createElement(
                        'div',
                        { className: 'text-xs text-gray-600 mb-2' },
                        React.createElement('span', { className: 'font-semibold' }, 'Focus: '),
                        session.focusArea
                      ),
                      React.createElement('div', { className: 'text-xs text-gray-700 mb-2' }, session.notes),
                      React.createElement(
                        'div',
                        { className: 'text-xs bg-green-50 border border-green-200 rounded p-2 text-green-900' },
                        React.createElement('strong', null, 'Practice adjustment: '),
                        session.practiceAdjustments
                      )
                    )
                  )
                )
              )
            )
          : React.createElement(
              'div',
              { className: 'text-center py-6' },
              React.createElement('div', { className: 'text-sm text-gray-600' }, 'No acting class added yet')
            )
      );
    }

    function RelationshipsModule({ data }) {
      const currentStage = getCurrentStage(data);

      return React.createElement(
        'div',
        { className: 'bg-white rounded border border-gray-200 p-6' },
        React.createElement('h2', { className: 'text-xs font-bold uppercase tracking-wide text-gray-900 mb-4 pb-3 border-b border-gray-200' }, 'Relationships'),
        React.createElement(
          'div',
          { className: 'mb-4 p-3 bg-blue-50 border border-blue-300 rounded' },
          React.createElement('div', { className: 'text-xs font-semibold text-blue-900 mb-1' }, 'Stage-Relevant Warm Relationships'),
          React.createElement(
            'div',
            { className: 'text-xs text-blue-800' },
            `${data.relationships.filter((r) => (r.warmth === 'Warm' || r.warmth === 'Active Collaborator') && r.stageRelevance.includes(currentStage)).length} active collaborators for ${STAGE_DEFINITIONS[currentStage].name}`
          )
        ),
        React.createElement(
          'div',
          { className: 'space-y-3' },
          data.relationships.map((rel) =>
            React.createElement(
              'div',
              { key: rel.id, className: 'border border-gray-300 rounded p-3' },
              React.createElement(
                'div',
                { className: 'flex justify-between items-start mb-2' },
                React.createElement(
                  'div',
                  null,
                  React.createElement('div', { className: 'text-sm font-bold text-gray-900' }, rel.name),
                  React.createElement('div', { className: 'text-xs text-gray-600' }, `${rel.role} • ${rel.category}`)
                ),
                React.createElement(
                  'span',
                  {
                    className: `text-xs px-2 py-1 rounded font-semibold ${
                      rel.warmth === 'Active Collaborator'
                        ? 'bg-green-100 text-green-800'
                        : rel.warmth === 'Warm'
                          ? 'bg-blue-100 text-blue-800'
                          : rel.warmth === 'Familiar'
                            ? 'bg-yellow-100 text-yellow-800'
                            : 'bg-gray-100 text-gray-800'
                    }`,
                  },
                  rel.warmth
                )
              ),
              React.createElement('div', { className: 'text-xs text-gray-700 mb-2' }, rel.howBradyHelps),
              React.createElement(
                'div',
                { className: 'text-xs text-gray-700 mb-2' },
                'How they help: ',
                rel.howTheyHelp
              ),
              React.createElement('div', { className: 'text-xs text-gray-600' }, 'Last interaction: ', React.createElement('strong', null, rel.lastInteraction)),
              React.createElement('div', { className: 'text-xs text-gray-600 mt-1' }, 'Next: ', React.createElement('strong', null, `${rel.nextAction} by ${rel.nextActionDate}`))
            )
          )
        )
      );
    }

    function SettingsPanel({ data, onUpdate }) {
      const handleExport = () => {
        const json = JSON.stringify(data, null, 2);
        const blob = new Blob([json], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `actor-producer-os-${new Date().toISOString().split('T')[0]}.json`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      };

      const handleImport = () => {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = '.json';
        input.onchange = (e) => {
          const file = e.target.files[0];
          if (!file) return;
          const reader = new FileReader();
          reader.onload = (event) => {
            try {
              const imported = JSON.parse(event.target.result);
              saveData(imported);
              onUpdate(imported);
              alert('Data imported successfully!');
            } catch {
              alert('Invalid file format');
            }
          };
          reader.readAsText(file);
        };
        input.click();
      };

      const handleOverride = (stageKey) => {
        const updated = { ...data, currentStageOverride: data.currentStageOverride === stageKey ? null : stageKey };
        saveData(updated);
        onUpdate(updated);
      };

      const currentStage = getCurrentStage(data);

      return React.createElement(
        'div',
        { className: 'bg-white rounded border border-gray-200 p-6' },
        React.createElement('h2', { className: 'text-xs font-bold uppercase tracking-wide text-gray-900 mb-4 pb-3 border-b border-gray-200' }, 'Settings'),
        React.createElement(
          'div',
          { className: 'space-y-6' },
          React.createElement(
            'div',
            null,
            React.createElement('h3', { className: 'text-xs font-bold uppercase tracking-wide text-gray-700 mb-3' }, 'Stage Override'),
            React.createElement(
              'div',
              { className: 'space-y-2' },
              Object.entries(STAGE_DEFINITIONS).map(([key, def]) =>
                React.createElement(
                  'button',
                  {
                    key: key,
                    onClick: () => handleOverride(key),
                    className: `block w-full text-left px-3 py-2 rounded border text-xs ${
                      data.currentStageOverride === key
                        ? 'border-orange-400 bg-orange-100 font-semibold'
                        : 'border-gray-300 bg-gray-50 hover:bg-gray-100'
                    }`,
                  },
                  `Stage ${key.split('stage')[1]}: ${def.name}${data.currentStageOverride === key ? ' [OVERRIDE]' : ''}`
                )
              )
            )
          ),
          React.createElement(
            'div',
            { className: 'border-t border-gray-200 pt-6' },
            React.createElement('h3', { className: 'text-xs font-bold uppercase tracking-wide text-gray-700 mb-3' }, 'Backup & Restore'),
            React.createElement(
              'div',
              { className: 'space-y-2' },
              React.createElement(
                'button',
                {
                  onClick: handleExport,
                  className: 'w-full px-4 py-2 bg-blue-600 text-white text-xs font-bold rounded hover:bg-blue-700',
                },
                '↓ Export Data'
              ),
              React.createElement(
                'button',
                {
                  onClick: handleImport,
                  className: 'w-full px-4 py-2 bg-green-600 text-white text-xs font-bold rounded hover:bg-green-700',
                },
                '↑ Import Data'
              )
            )
          ),
          React.createElement(
            'div',
            { className: 'border-t border-gray-200 pt-6 text-xs text-gray-600' },
            React.createElement('div', { className: 'mb-2' }, React.createElement('strong', null, 'Schema Version: '), data.schemaVersion),
            React.createElement('div', null, React.createElement('strong', null, 'Last Updated: '), new Date(data.lastUpdated).toLocaleString())
          )
        )
      );
    }

    // ===== MAIN APP =====

    function App() {
      const [data, setData] = useState(loadData());
      const [activeTab, setActiveTab] = useState('dashboard');

      const handleDataUpdate = (newData) => {
        setData(newData);
      };

      const currentStage = getCurrentStage(data);
      const stageName = STAGE_DEFINITIONS[currentStage].name;

      return React.createElement(
        React.Fragment,
        null,
        // Header
        React.createElement(
          'div',
          { className: 'bg-gradient-to-r from-navy-900 to-gray-900 text-white px-6 py-8' },
          React.createElement(
            'div',
            { className: 'max-w-7xl mx-auto' },
            React.createElement(
              'div',
              { className: 'flex items-center justify-between' },
              React.createElement(
                'div',
                null,
                React.createElement('h1', { className: 'text-3xl font-bold uppercase tracking-tight' }, 'Actor / Producer OS'),
                React.createElement('p', { className: 'text-sm text-gray-300 mt-1' }, `Career decision engine for ${stageName}`)
              ),
              React.createElement('div', { className: 'text-orange-400 text-3xl' }, '▬')
            )
          )
        ),
        // Nav
        React.createElement(
          'div',
          { className: 'border-b border-gray-300 bg-gray-50 sticky top-0 z-10' },
          React.createElement(
            'div',
            { className: 'max-w-7xl mx-auto px-6' },
            React.createElement(
              'div',
              { className: 'flex gap-1 overflow-x-auto' },
              [
                { id: 'dashboard', label: 'Daily Checkin' },
                { id: 'writing', label: 'Writing' },
                { id: 'acting', label: 'Acting' },
                { id: 'relationships', label: 'Relationships' },
                { id: 'settings', label: 'Settings' },
              ].map((tab) =>
                React.createElement(
                  'button',
                  {
                    key: tab.id,
                    onClick: () => setActiveTab(tab.id),
                    className: `px-4 py-3 text-xs font-bold uppercase tracking-wide border-b-2 transition ${
                      activeTab === tab.id
                        ? 'border-orange-400 text-orange-600'
                        : 'border-transparent text-gray-600 hover:text-gray-900'
                    }`,
                  },
                  tab.label
                )
              )
            )
          )
        ),
        // Content
        React.createElement(
          'div',
          { className: 'max-w-7xl mx-auto px-6 py-8' },
          activeTab === 'dashboard' && DailyCheckIn({ data, onUpdate: handleDataUpdate }),
          activeTab === 'writing' && WritingModule({ data, onUpdate: handleDataUpdate }),
          activeTab === 'acting' && ActingModule({ data }),
          activeTab === 'relationships' && RelationshipsModule({ data }),
          activeTab === 'settings' && SettingsPanel({ data, onUpdate: handleDataUpdate })
        ),
        // Footer
        React.createElement(
          'div',
          { className: 'border-t border-gray-300 bg-gray-50 mt-12 py-6' },
          React.createElement(
            'div',
            { className: 'max-w-7xl mx-auto px-6 text-center text-xs text-gray-600' },
            React.createElement('p', null, 'Data persists locally in your browser. Backup regularly via Settings.')
          )
        )
      );
    }

    // ===== RENDER =====

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(React.createElement(App));
  </script>
</body>
</html>
