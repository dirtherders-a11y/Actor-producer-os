        if (!activeFeature) return;
        const updatedData = { ...data };
        const feature = updatedData.featureScreenplays.find((f) => f.id === activeFeature.id);
        if (!feature) return;

        const pages = parseInt(sessionPages) || 3;
        feature.currentPages += pages;
        feature.writingSessions.push({
          id: `ws${Date.now()}`,
          featureId: feature.id,
          date: new Date().toISOString().split('T')[0],
          pagesWritten: pages,
          notes: sessionNotes,
        });

        if (feature.currentPages >= feature.targetPages) {
          feature.status = 'First Draft Complete';
          feature.completedDate = new Date().toISOString();
        }

        saveData(updatedData);
        onUpdate(updatedData);
        setSessionPages('3');
        setSessionNotes('');
        setShowNewSession(false);
      };

      return React.createElement(
        'div',
