    // ===== HELPER FUNCTIONS =====

    function getCurrentStage(data) {
      if (data.currentStageOverride) {
        return data.currentStageOverride;
      }
      for (let i = 5; i >= 0; i--) {
        const stageKey = `stage${i}`;
        const stageGates = data.hardGates.filter((g) => g.stageKey === stageKey);
        const expectedGates = STAGE_DEFINITIONS[stageKey] ? 1 : 0;
        if (stageGates.length === 0) continue;
        const completedGates = stageGates.filter((g) => g.completed).length;
        if (completedGates < expectedGates) return stageKey;
      }
      return 'stage0';
    }

    function getActiveFeature(data) {
      return data.featureScreenplays.find((f) => f.status === 'Drafting') || null;
    }

    function getPagesPerActiveDay(feature) {
      if (feature.writingSessions.length === 0) return 0;
      const totalPages = feature.writingSessions.reduce((sum, s) => sum + s.pagesWritten, 0);
      return totalPages / feature.writingSessions.length;
    }

    function getStageCompletion(stageKey, data) {
      const gates = data.hardGates.filter((g) => g.stageKey === stageKey);
      if (gates.length === 0) return 0;
      const completed = gates.filter((g) => g.completed).length;
      return (completed / gates.length) * 100;
    }

    function saveData(data) {
      const updated = { ...data, lastUpdated: new Date().toISOString() };
      localStorage.setItem('actor-producer-os', JSON.stringify(updated));
    }

    function loadData() {
      const stored = localStorage.getItem('actor-producer-os');
      if (stored) {
        try {
          return JSON.parse(stored);
        } catch {
          return SEED_DATA;
        }
      }
      return SEED_DATA;
    }

